{
  "name": "repo2learn",
  "version": "0.1.0",
  "private": true,
  "description": "Turn any repository into a layered, bilingual, interactive tutorial site — powered by codex sub-agents.",
  "type": "module",
  "bin": {
    "repo2learn": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "learn:sample": "tsx src/index.ts --sample",
    "site:dev": "npm -w site run dev",
    "site:build": "npm -w site run build",
    "site:start": "npm -w site run start"
  },
  "workspaces": [
    "site"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
